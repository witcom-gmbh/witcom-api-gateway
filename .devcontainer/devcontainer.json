// For format details, see https://aka.ms/vscode-remote/devcontainer.json or this file's README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.195.0/containers/java
{
	"name": "witcom-api-gateway",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",

	// Set *default* container specific settings.json values on container create.
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {
			// Set *default* container specific settings.json values on container create.
			"settings": {
				"java.jdt.ls.java.home": "/usr/lib/jvm/msopenjdk-current",
				"maven.executable.path": "/usr/local/sdkman/candidates/maven/current/bin/mvn",
				"spring-boot.ls.java.home": "/usr/lib/jvm/msopenjdk-current",
				"java.configuration.runtimes": [
					{
					"name": "JavaSE-21",
					"path": "/usr/lib/jvm/msopenjdk-current",
					"default": true
					}
				],
				// check-style-related configuration
				"java.checkstyle.configuration": "${workspaceFolder}/witcom-checks.xml",
				"java.checkstyle.version": "10.24.0",
				"java.format.settings.url": "${workspaceFolder}/eclipse-java-witcom-style.xml",
				// match with check-style configuration
				"java.completion.importOrder": [
					"#",
					"java",
					"javax",
					"org",
					""
				],
				"[java]": {
					"editor.useTabStops": false,
					"editor.tabSize": 4,
					"editor.insertSpaces": true
				}
			},
			"extensions": [
				"vscjava.vscode-java-pack",
				"vmware.vscode-boot-dev-pack",
				"redhat.java",
				"vmware.vscode-boot-dev-pack",
				"sonarsource.sonarlint-vscode",
				"shengchen.vscode-checkstyle"
			]
		}
	},

	//"runArgs": ["--network=confluent-platform_default"],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		8080,
		"keycloak:9999",
		"mockserver:1080"

	],
	"portsAttributes": {
			"8080": {
					"label": "Application"
			},
			"keycloak:9999": {
					"label": "Keycloak"
			},
			"mockserver:1080": {
					"label": "Mockserver"
			}
	},

	"initializeCommand": [".devcontainer/init"],
	// Use 'postCreateCommand' to run commands after the container is created.
	"postStartCommand": ".devcontainer/postStartCommand",
	// Uncomment to connect as a non-root user. See https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "vscode",

	"remoteEnv": {
		"CHEZMOI_REPO": "${localEnv:CHEZMOI_REPO}"
	},
	"features": {
		"ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {
			"jqVersion": "latest",
			"yqVersion": "latest",
			"gojqVersion": "none",
			"xqVersion": "none",
			"jaqVersion": "none"
		},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
			"version": "latest",
			"helm": "latest",
			"minikube": "none"
		},
		"ghcr.io/devcontainers-extra/features/age:1": {"version": "v1.1.1"},
		// "ghcr.io/devcontainers-contrib/features/age-keygen:1": {"version": "v1.1.1"},
		"ghcr.io/rio/features/chezmoi:1": {},
		"ghcr.io/witcom-gmbh/devcontainer-features/cocogitto:latest": {},
		"ghcr.io/witcom-gmbh/devcontainer-features/helmdocs:latest": {},
		"ghcr.io/devcontainers/features/java:1": {
			"version": "none",
			"installGradle": "false",
			"installMaven": "true"
		}
	}
}
